# === Database Configuration (REQUIRED) ===
# URL должен быть в формате PostgresDsn
APP_CONFIG__DB__URL=postgresql+asyncpg://user:password@localhost:5432/dbname


# === Access Token Secrets (REQUIRED) ===
# Сгенерировать токены доступа можно при помощи данной команды: python -c "import secrets; print(f'RESET_SECRET: {secrets.token_urlsafe(32)}\nVERIFICATION_SECRET: {secrets.token_urlsafe(32)}')"
APP_CONFIG__ACCESS_TOKEN__RESET_PASSWORD_TOKEN_SECRET=your-super-secret-reset-token
APP_CONFIG__ACCESS_TOKEN__VERIFICATION_TOKEN_SECRET=your-super-secret-verification-token
